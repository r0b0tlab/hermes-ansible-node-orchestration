#!/usr/bin/env bash
set -euo pipefail

RUN_DIR={{ benchmark_runner_run_dir | quote }}
mkdir -p "$RUN_DIR"
cd "$RUN_DIR"

cat > run-meta.json <<'JSON'
{
  "benchmark": "{{ benchmark_runner_kind }}",
  "model_key": "{{ benchmark_runner_model_key }}",
  "model_alias": "{{ benchmark_runner_model_alias }}",
  "endpoint_url": "{{ benchmark_runner_endpoint_url }}",
  "run_id": "{{ benchmark_runner_run_id }}",
  "custom_command": true
}
JSON

{{ benchmark_runner_custom_command }} 2>&1 | tee "$RUN_DIR/run.log"
sha256sum "$RUN_DIR"/* > "$RUN_DIR/MANIFEST.sha256" 2>/dev/null || true
